HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=https://your-storefront.com
PUBLIC_ORDER_ACCESS_TTL_HOURS=24
# Optional override for QA/testing. If set, minutes take precedence over hours.
PUBLIC_ORDER_ACCESS_TTL_MINUTES=

# Wompi El Salvador payment gateway
# Preferred names used by this project. WOMPI_URL_AUTH/WOMPI_URL_API aliases are also supported.
WOMPI_TOKEN_URL=https://id.wompi.sv/connect/token
WOMPI_API_URL=https://api.wompi.sv
WOMPI_URL_AUTH=https://id.wompi.sv/connect/token
WOMPI_URL_API=https://api.wompi.sv
WOMPI_CLIENT_ID=
WOMPI_CLIENT_SECRET=
# Final customer return page in the storefront. When this points to the thank-you page,
# the backend uses WOMPI_BACKEND_URL (or WOMPI_WEBHOOK_URL) to send Wompi first to /api/wompi/redirect.
WOMPI_REDIRECT_URL=https://your-storefront.com/checkout/gracias-por-su-compra
WOMPI_RETURN_URL=https://your-storefront.com/checkout/gracias-por-su-compra
WOMPI_BACKEND_URL=https://your-strapi-tunnel.example.com
WOMPI_STOREFRONT_URL=https://your-storefront.com
WOMPI_THANK_YOU_PATH=/checkout/gracias-por-su-compra
WOMPI_NOTIFICATION_EMAILS=
# Wompi only accepts a public HTTPS webhook URL. Leave both empty in QA/local when you do not have a domain yet.
# Server-to-server payment confirmation; use the Strapi public HTTPS URL.
WOMPI_WEBHOOK_URL=
# Optional public HTTPS tunnel/QA URL, for example https://xxxx.ngrok-free.app/api/payments/wompi/webhook
# Use false to disable the override and use WOMPI_WEBHOOK_URL instead.
WOMPI_WEBHOOK_QA_OVERRIDE=false

# Rate limiting for public checkout/payment endpoints
# Set RATE_LIMIT_ENABLED=false to disable all route-level rate limits.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
RATE_LIMIT_ORDERS_CREATE_MAX=10
RATE_LIMIT_WOMPI_CHECKOUT_MAX=10
RATE_LIMIT_WOMPI_PAYMENT_LINK_MAX=10
RATE_LIMIT_WOMPI_WEBHOOK_MAX=120
RATE_LIMIT_ORDERS_PUBLIC_MAX=20
