{
  "kind": "collectionType",
  "collectionName": "variant_options",
  "info": {
    "singularName": "variant-option",
    "pluralName": "variant-options",
    "displayName": "Variant Option"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "label": {
      "type": "string",
      "required": true
    },
    "value": {
      "type": "string",
      "required": true
    },
    "price_override": {
      "type": "string"
    },
    "active": {
      "type": "boolean",
      "default": true
    },
    "product": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product.product",
      "inversedBy": "variants"
    },
    "stocks": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::branch-stock.branch-stock",
      "mappedBy": "variant"
    },
    "images": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product-image.product-image",
      "mappedBy": "variant"
    },
    "items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::order-item.order-item",
      "mappedBy": "variant"
    }
  }
}
