{
  "kind": "collectionType",
  "collectionName": "checkout_attempts",
  "info": {
    "singularName": "checkout-attempt",
    "pluralName": "checkout-attempts",
    "displayName": "Checkout Attempt"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "tracking_number": { "type": "string", "required": true, "unique": true },
    "checkout_attempt_id": { "type": "string", "unique": true, "private": true },
    "customer_name": { "type": "string", "required": true },
    "customer_email": { "type": "email", "required": true },
    "customer_phone": { "type": "string", "required": true },
    "delivery_type": { "type": "enumeration", "required": true, "enum": ["delivery", "pickup"] },
    "address": { "type": "string", "required": false },
    "subtotal": { "type": "decimal", "required": true },
    "shipping_cost": { "type": "decimal", "required": true },
    "total": { "type": "decimal" },
    "items": { "type": "json", "required": true },
    "payment_status": {
      "type": "enumeration",
      "default": "pending",
      "enum": ["pending", "paid", "failed", "expired"]
    },
    "wompi_transaction_id": { "type": "string" },
    "wompi_transaction_status": { "type": "string" },
    "wompi_transaction_message": { "type": "text" },
    "wompi_authorization_code": { "type": "string" },
    "wompi_payment_method": { "type": "string" },
    "wompi_payment_link_id": { "type": "integer" },
    "wompi_payment_link_url": { "type": "string" },
    "wompi_payment_link_long_url": { "type": "string" },
    "wompi_payment_link_qr_url": { "type": "string" },
    "expires_at": { "type": "datetime", "required": true },
    "payment_reservation_expires_at": { "type": "datetime", "private": true },
    "stock_released": { "type": "boolean", "default": false, "private": true },
    "materialized": { "type": "boolean", "default": false, "private": true },
    "branch": { "type": "relation", "relation": "manyToOne", "target": "api::branch.branch" },
    "shipping_rate": { "type": "relation", "relation": "manyToOne", "target": "api::shipping-rate.shipping-rate" },
    "order": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::order.order",
      "mappedBy": "checkout_attempt"
    }
  }
}