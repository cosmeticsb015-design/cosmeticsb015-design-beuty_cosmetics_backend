{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "tracking_number": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "checkout_attempt_id": {
      "type": "string",
      "unique": true,
      "private": true
    },
    "customer_name": {
      "type": "string",
      "required": true
    },
    "customer_email": {
      "type": "email",
      "required": true
    },
    "customer_phone": {
      "type": "string",
      "required": true
    },
    "delivery_type": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "delivery",
        "pickup"
      ]
    },
    "address": {
      "type": "string",
      "required": false
    },
    "subtotal": {
      "type": "decimal",
      "required": true
    },
    "shipping_cost": {
      "type": "decimal",
      "required": true
    },
    "total": {
      "type": "decimal"
    },
    "order_status": {
      "type": "enumeration",
      "default": "pending_shipping",
      "enum": [
        "pending_shipping",
        "shipped",
        "delivered"
      ]
    },
    "fulfillment_status": {
      "type": "enumeration",
      "default": "pending_shipping",
      "enum": [
        "pending_shipping",
        "shipped",
        "delivered"
      ]
    },
    "payment_status": {
      "type": "enumeration",
      "default": "pending",
      "enum": [
        "pending",
        "paid",
        "failed",
        "refunded"
      ]
    },
    "internal_payment_status": {
      "type": "enumeration",
      "enum": [
        "pending",
        "paid",
        "failed",
        "refunded"
      ]
    },
    "wompi_payment_status": {
      "type": "enumeration",
      "enum": [
        "pending",
        "paid",
        "failed",
        "refunded"
      ]
    },
    "wompi_transaction_id": {
      "type": "string"
    },
    "wompi_transaction_status": {
      "type": "string"
    },
    "wompi_transaction_message": {
      "type": "text"
    },
    "wompi_authorization_code": {
      "type": "string"
    },
    "wompi_payment_method": {
      "type": "string"
    },
    "expires_at": {
      "type": "datetime",
      "required": true
    },
    "branch": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::branch.branch",
      "inversedBy": "orders"
    },
    "shipping_rate": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::shipping-rate.shipping-rate",
      "inversedBy": "orders"
    },
    "items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::order-item.order-item",
      "mappedBy": "order"
    },
    "wompi_payment_link_id": {
      "type": "integer"
    },
    "wompi_payment_link_url": {
      "type": "string"
    },
    "wompi_payment_link_long_url": {
      "type": "string"
    },
    "wompi_payment_link_qr_url": {
      "type": "string"
    }
  }
}
